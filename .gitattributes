# Normalize line endings: LF in the repo, platform-native on checkout
* text=auto

# Force LF for source files (consistent regardless of OS)
*.rs    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.ico   binary
*.icns  binary
